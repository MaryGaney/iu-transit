# ── IU Transit Tracker — Environment Config ──────────────────────────────────
# Copy this to .env and fill in values. Never commit .env to git.

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/transit.db

# GTFS static feed (Bloomington Transit)
GTFS_STATIC_URL=https://bloomingtontransit.com/gtfs/google_transit.zip

# GTFS-RT vehicle positions endpoint
# Bloomington Transit uses a Swiftly/TransLoc backend.
# Primary candidates (try in order until one returns protobuf data):
GTFS_RT_VEHICLE_URL=https://gtfsrt.api.translink.com.au/api/feed/gtfsrt/vehicles
# Fallback: many BT deployments expose this path
GTFS_RT_VEHICLE_URL_ALT=https://bloomingtontransit.com/gtfs/vehiclepositions.pb

# Open-Meteo (free, no API key required)
WEATHER_API_URL=https://api.open-meteo.com/v1/forecast
# Bloomington, IN coordinates
BLOOMINGTON_LAT=39.1653
BLOOMINGTON_LNG=-86.5264

# IU Buildings API (public, used once to geocode building codes)
IU_BUILDINGS_URL=https://api.iub.edu/buildings/v1

# Mapbox token (for frontend — set here for backend to serve to client)
MAPBOX_TOKEN=pk.your_mapbox_token_here

# LSTM model path
LSTM_MODEL_PATH=./data/lstm_model.pt
LSTM_SCALER_PATH=./data/feature_scaler.pkl

# Polling intervals (seconds)
GTFS_RT_POLL_INTERVAL=15
WEATHER_POLL_INTERVAL=300
CLASS_SCHEDULE_REFRESH_INTERVAL=3600

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── LLM Travel Agent (HuggingFace Inference API) ─────────────────────────────
# Free with a HuggingFace account — no credit card required
# 1. Sign up at https://huggingface.co
# 2. Go to https://huggingface.co/settings/tokens
# 3. Create a new token (read access is enough)
# 4. Paste it here
HF_TOKEN=hf_your_token_here

# Model to use (default: Mistral-7B-Instruct — strong, fast, free)
# Alternatives:
#   meta-llama/Llama-3.2-3B-Instruct  (smaller, faster)
#   Qwen/Qwen2.5-7B-Instruct          (also excellent)
HF_MODEL=mistralai/Mistral-7B-Instruct-v0.3
